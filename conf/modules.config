/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
    ]

    withName: '.*:STRINGTIE_MERGE.*' {
        ext.args = { "-T ${params.min_stringtie_tpm}" }
    }

    withName: '.*:MERGEFUSIONS.*|.*:FUSIONFASTA.*' {
        publishDir = [
            [
                path: { "${params.outdir}/proteome/NDR_${params.NDR}" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
                enabled: params.NDR ? true : false,
            ],
            [
                path: { "${params.outdir}/proteome/NDR_DEFAULT" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
                enabled: params.recommended_NDR ? true : false,
            ],
        ]
    }

    withName: '.*:TRANSDECODER2FASTA.*' {
        publishDir = [
            [
                path: { "${params.outdir}/proteome/NDR_${meta.NDR ?: params.NDR ?: 'DEFAULT'}" },
                mode: params.publish_dir_mode,
                saveAs: { filename ->
                    if (filename.equals('versions.yml')) {
                        return null
                    }
                    return meta.tool == 'bambu' ? filename : null
                },
            ],
            [
                path: { "${params.outdir}/proteome/NDR_${params.NDR}" },
                mode: params.publish_dir_mode,
                saveAs: { filename ->
                    if (filename.equals('versions.yml')) {
                        return null
                    }
                    return meta.tool == 'stringtie' && params.NDR ? filename : null
                },
            ],
            [
                path: { "${params.outdir}/proteome/NDR_DEFAULT" },
                mode: params.publish_dir_mode,
                saveAs: { filename ->
                    if (filename.equals('versions.yml')) {
                        return null
                    }
                    return meta.tool == 'stringtie' && params.recommended_NDR ? filename : null
                },
            ],
        ]
    }

    withName: '.*:CAT_CAT.*' {
        publishDir = [
            enabled: false
        ]
    }

    withName: '.*:SEQKIT_RMDUP.*' {
        ext.args   = "-s"
        ext.prefix = { "${meta.id}.proteome" }
        publishDir = [
            path: { "${params.outdir}/proteome/NDR_${meta.NDR}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: '.*:SEQKIT_STATS.*' {
        ext.prefix = { "${meta.id}.seqkit_stats" }
        publishDir = [
            path: { "${params.outdir}/proteome/NDR_${meta.NDR}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: DIAMOND_BLASTP {
        ext.args = { "--max-target-seqs 1 --evalue ${params.max_evalue}" }
    }

    withName: '.*:BAMBU.*' {
        publishDir = [
            path: { "${params.outdir}/bambu/${meta.id}/transcriptome_NDR_${meta.NDR}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }


    withName: 'KENTSISLAB_PROTEOMEGENERATOR3:PROTEOMEGENERATOR3:BAM_ASSEMBLY_BAMBU:BAMBU_FILTER' {
        ext.args   = { "--min_cts=${params.min_lr_cts}" }
        publishDir = [
            path: { "${params.outdir}/bambu/${meta.id}/transcriptome_NDR_${meta.NDR}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: 'KENTSISLAB_PROTEOMEGENERATOR3:PROTEOMEGENERATOR3:PREPROCESS_READS:BAMBU_READCLASSES' {
        publishDir = [
            path: { "${params.outdir}/bambu/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }
    withName: '.*:(TRANSDECODER_PREDICT|TRANSDECODER_LONGORF)' {
        publishDir = [
            path: { "${params.outdir}/transdecoder/NDR_${meta.NDR}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: '.*:TRANSDECODER_PREDICT.*' {
        ext.args = params.single_best_only ? '--single_best_only' : ''
    }

    withName: '.*:TRANSDECODER_LONGORF.*' {
        ext.args = { "-m ${params.min_orf_len}" }
    }

    withName: GFFREAD {
        ext.args = '-w'
    }

    withName: SAMTOOLS_VIEW {
        ext.prefix = { "${meta.id}.filtered" }
        ext.args   = '--output-fmt bam'
        ext.args2  = [
            "chr1",
            "chr2",
            "chr3",
            "chr4",
            "chr5",
            "chr6",
            "chr7",
            "chr8",
            "chr9",
            "chr10",
            "chr11",
            "chr12",
            "chr13",
            "chr14",
            "chr15",
            "chr16",
            "chr17",
            "chr18",
            "chr19",
            "chr20",
            "chr21",
            "chr22",
            "chrX",
            "chrY",
            "chrM",
        ].join(' ')
    }

    withName: FILTER_READS {
        ext.prefix = { "${meta.id}.filtered" }
        ext.args   = "-e \"mapq >= ${params.mapq} && length(seq) >= ${params.read_len} \" --output-fmt bam"
        ext.args2  = ""
        cpus       = { 5 * task.attempt }
        memory     = { 30.GB * task.attempt }
        time       = { 4.h * task.attempt }
    }

    withName: BAMBU_READCLASSES {
        cpus   = { 1 * task.attempt }
        memory = { 200.GB * task.attempt }
        time   = { 6.h * task.attempt }
    }

    withName: BAMBU_MERGE {
        ext.args      = "--quant=FALSE --lowMemory=FALSE"
        ext.yieldsize = "NULL"
        cpus          = { 1 }
        memory        = { rds.size() > 20 ? 300.GB * task.attempt : 200.GB * task.attempt }
        time          = { rds.size() > 20 ? 24.h * task.attempt : 12.h * task.attempt }
    }

    withName: '.*:BAMBU_MERGE_QUANT.*' {
        container  = "quay.io/shahlab_singularity/bambu:HongYhong_fix"
        ext.args   = "--discovery=FALSE"
        cpus       = { 1 }
        memory     = { 100.GB * task.attempt }
        time       = { 2.h * task.attempt }
        maxRetries = 2
        publishDir = [
            path: { "${params.outdir}/bambu/merge/transcriptome_NDR_${meta.NDR}/quant/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: '.*:SEMERGE.*' {
        publishDir = [
            path: { "${params.outdir}/bambu/${meta.id}/transcriptome_NDR_${meta.NDR}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: MULTIQC {
        ext.args   = { params.multiqc_title ? "--title \"${params.multiqc_title}\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    //
    // LRAA modules
    //
    withName: '.*:LRAA_ASSEMBLY.*' {
        publishDir = [
            path: { "${params.outdir}/lraa/assembly/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: '.*:LRAA_MERGE.*' {
        publishDir = [
            path: { "${params.outdir}/lraa/merged" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: '.*:LRAA_QUANT$' {
        publishDir = [
            path: { "${params.outdir}/lraa/quant/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: '.*:LRAA_QUANTMERGE$' {
        publishDir = [
            path: { "${params.outdir}/lraa/quant" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    //
    // StringTie long-read mode: pass -L flag only for the LR-aliased instance
    //
    withName: 'KENTSISLAB_PROTEOMEGENERATOR3:PROTEOMEGENERATOR3:BAM_ASSEMBLY_STRINGTIE_LR:STRINGTIE_STRINGTIE' {
        ext.args = '-L'
    }

    withName: 'KENTSISLAB_PROTEOMEGENERATOR3:PROTEOMEGENERATOR3:BAM_ASSEMBLY_STRINGTIE_SR:STRINGTIE_STRINGTIE' {
        ext.args = ''
    }

    //
    // LRAA reannotation: use LRAA-specific novel transcript/gene prefixes
    //
    withName: '.*:BAM_ASSEMBLY_LRAA:REANNOTATEGTF' {
        ext.args = '--tool lraa'
    }

    withName: '.*:LRAA_SQANTI.*' {
        publishDir = [
            path: { "${params.outdir}/lraa/sqanti" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: '.*:LRAA_REANNOTATEQUANT.*' {
        publishDir = [
            path: { "${params.outdir}/lraa/quant/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }
}
